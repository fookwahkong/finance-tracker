SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your-anon-or-service-key
ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_BOT_TOKEN=...
TELEGRAM_WEBHOOK_SECRET=your-random-secret-string
ALLOWED_ORIGINS=http://localhost:5173

# LLM provider: "ollama" for local dev, "claude" for production
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

SHORTCUT_API_KEY=     # Static secret shared between iOS Shortcut and Vercel, can be a password you set yourself
CRON_SECRET=     # Secret Vercel sends on cron requests; set in Vercel dashboard 
GMAIL_CREDENTIALS=          #OAuth2 token JSON for Gmail API (from one-time local setup)
GMAIL_QUERY= #Gmail search query to filter bank notification emails

POLYGON_API_KEY=     # Polygon.io API key (free tier). https://polygon.io/dashboard/api-keys
