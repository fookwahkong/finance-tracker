SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# The two fixed accounts (UUIDs from Supabase Auth > Users)
PERSONAL_USER_ID=00000000-0000-0000-0000-000000000000
DEMO_USER_ID=00000000-0000-0000-0000-000000000000
DEMO_EMAIL=demo@finance-tracker.app
DEMO_PASSWORD=change-me-public-demo

# Frontend (Vite) — anon key + demo creds are intentionally public
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_DEMO_EMAIL=demo@finance-tracker.app
VITE_DEMO_PASSWORD=change-me-public-demo

ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_BOT_TOKEN=...
TELEGRAM_WEBHOOK_SECRET=your-random-secret-string
ALLOWED_ORIGINS=http://localhost:5173

# LLM provider: "ollama" for local dev, "claude" for production
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

CRON_SECRET=     # Secret Vercel sends on cron requests; set in Vercel dashboard
GMAIL_CREDENTIALS=          #OAuth2 token JSON for Gmail API (from one-time local setup)
GMAIL_QUERY= #Gmail search query to filter bank notification emails

POLYGON_API_KEY=     # Polygon.io API key (free tier). https://polygon.io/dashboard/api-keys
FMP_API_KEY=
FINNHUB_API_KEY=

# Optional: error tracking (GlitchTip / Sentry-compatible). Leave unset to send nothing.
SENTRY_DSN=
VITE_SENTRY_DSN=